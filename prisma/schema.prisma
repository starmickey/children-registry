generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Child {
  id                 Int            @id @default(autoincrement())
  firstName          String         @map("first_name")
  lastName           String         @map("last_name")
  identityCardNumber String?        @map("identity_card_number")
  birthDate          DateTime?      @map("birth_date")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  removedAt          DateTime?      @map("removed_at")
  registrations      Registration[]
  childRelationships Relationship[]
  pinGrants          PinGrant[]
  permissions        Permission[]

  @@index([removedAt])
  @@map("children")
}

model Registration {
  childId   Int       @map("child_id")
  classId   Int       @map("class_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  removedAt DateTime? @map("removed_at")
  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([childId, classId])
  @@index([childId, removedAt, createdAt(sort: Desc)])
  @@map("registrations")
}

model Class {
  id            Int            @id @default(autoincrement())
  year          Int
  classroomId   Int?           @map("classroom_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  removedAt     DateTime?      @map("removed_at")
  classroom     Classroom?     @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  registrations Registration[]

  @@index([classroomId])
  @@index([removedAt])
  @@map("classes")
}

model Classroom {
  id        Int       @id @default(autoincrement())
  name      String
  alias     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  removedAt DateTime? @map("removed_at")
  classes   Class[]

  @@index([removedAt])
  @@map("classrooms")
}

model Contact {
  id                 Int            @id @default(autoincrement())
  firstName          String         @map("first_name")
  lastName           String         @map("last_name")
  identityCardNumber String?        @map("identity_card_number")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  removedAt          DateTime?      @map("removed_at")
  phones             Phone[]
  contactRelations   Relationship[]

  @@index([removedAt])
  @@map("contacts")
}

model Phone {
  id        Int       @id @default(autoincrement())
  number    String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  removedAt DateTime? @map("removed_at")
  contactId Int       @map("contact_id")
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId]) // FK index: Crucial for queries matching phones to contacts
  @@index([removedAt])
  @@map("phones")
}

model RelationshipType {
  id        Int            @id @default(autoincrement())
  name      String
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  removedAt DateTime?      @map("removed_at")
  relations Relationship[]

  @@index([removedAt])
  @@map("relationship_types")
}

model Relationship {
  childId            Int              @map("child_id")
  contactId          Int              @map("contact_id")
  relationshipTypeId Int              @map("relationship_type_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  removedAt          DateTime?        @map("removed_at")
  child              Child            @relation(fields: [childId], references: [id], onDelete: Cascade)
  contact            Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  relationshipType   RelationshipType @relation(fields: [relationshipTypeId], references: [id], onDelete: Restrict)

  @@id([childId, contactId, relationshipTypeId])
  @@index([contactId]) // Indexed for direct lookup on contact side
  @@index([relationshipTypeId]) // Indexed for filtering by relationship types
  @@index([removedAt])
  @@map("relationships")
}

model PinGrant {
  childId   Int       @map("child_id")
  pinId     Int       @map("pin_id")
  grantedAt DateTime  @map("granted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  removedAt DateTime? @map("removed_at")
  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  pin       Pin       @relation(fields: [pinId], references: [id], onDelete: Restrict)

  @@id([childId, pinId])
  @@index([pinId]) // Explicitly indexed for looking up who holds specific PINs
  @@index([removedAt])
  @@map("pin_grants")
}

model Pin {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  removedAt DateTime?  @map("removed_at")
  pinGrants PinGrant[]

  @@index([removedAt])
  @@map("pins")
}

model Permission {
  childId          Int            @map("child_id")
  permissionTypeId Int            @map("permission_type_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  removedAt        DateTime?      @map("removed_at")
  child            Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  permissionType   PermissionType @relation(fields: [permissionTypeId], references: [id], onDelete: Restrict)

  @@id([childId, permissionTypeId, createdAt])
  @@index([permissionTypeId])
  @@index([removedAt])
  @@map("permissions")
}

model PermissionType {
  id          Int          @id @default(autoincrement())
  shortName   String       @map("short_name")
  name        String
  enabled     Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  removedAt   DateTime?    @map("removed_at")
  permissions Permission[]

  @@index([removedAt])
  @@map("permission_types")
}
